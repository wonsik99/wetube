header
    a(href="/").header__logo
        i.fab.fa-youtube
    nav
        ul
            if !loggedIn
                li
                    a(href="/join") Join
                li
                    a(href="/login") Login
            else
                li
                    a(href="/videos/upload") Upload Video
                li 
                    a(href=`/users/${user._id}`)
                        if !user.avatarUrl
                            span 😀
                        else
                            img.header__avatar(src=user.avatarUrl, alt=user.name)
                li 
                    a(href="/users/edit") Edit Profile
                li 
                    a(href="/users/logout") Logout
            li
                a(href="/search") Search