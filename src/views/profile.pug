extends base
include mixins/video

block content
  div.profile__data
    if user.avatarUrl
      img.avatar(src=(user.avatarUrl.startsWith("http") ? user.avatarUrl : "/" + user.avatarUrl), alt=user.name)
    h3= user.name
  div.video-grid
    each video in user.videos
      +video(video)
    else
      span.empty__message No videos found.
