extends base

block content
    if errorMessage
        span=errorMessage
    h1 Change Password
    form(method="POST")
        input(name="oldPassword", placeholder="Old Password", required, type="password")
        input(name="newPassword", placeholder="New Password", required, type="password")
        input(name="newPasswordConfirmation", placeholder="New Password Confirmation", required, type="password")
        input(type="submit", value="Change Password")