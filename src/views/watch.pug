extends base

block content
    video(src="/" + video.fileUrl, controls)
    div 
        p=video.description
        small=video.createdAt
    div
        small Uploaded by 
            a(href=`/users/${video.owner._id}`)=video.owner.name
    if String(video.owner._id) === String(user._id)
        a(href=`/videos/${video._id}/edit`) Edit Video &rarr;
        br
        a(href=`/videos/${video._id}/delete`) Delete Video &rarr;
